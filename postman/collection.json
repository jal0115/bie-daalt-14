  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response time is below 2000ms\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has accessToken\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.property(\"accessToken\");\r",
                  "    pm.expect(d.accessToken).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type is JSON\", () => {\r",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "// Chain — token хадгалах\r",
                  "const json = pm.response.json();\r",
                  "pm.environment.set(\"token\", json.accessToken);\r",
                  "pm.environment.set(\"userId\", json.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\t\"username\": \"emilys\",\r\n\t\"password\": \"emilyspass\",\r\n\t\"expiresInMins\": 30\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has user id and email\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.property(\"id\");\r",
                  "    pm.expect(d).to.have.property(\"email\");\r",
                  "    pm.expect(d.email).to.match(/@/);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "response": []
        }
      ]
    },
