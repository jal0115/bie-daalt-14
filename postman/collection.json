                "exec": [
                  "// Chain — дараагийн request-д хэрэглэх token хадгалах\r",
                  "const json = pm.response.json();\r",
                  "pm.environment.set(\"token\", json.accessToken);\r",
                  "pm.environment.set(\"userId\", json.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n\t\"username\": \"emilys\",\r\n\t\"password\": \"emilyspass\",\r\n\t\"expiresInMins\": 30\r\n}",
              "options": {
                "raw": {
                  "language": "json"
